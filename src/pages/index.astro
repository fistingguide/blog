---
import { getVisitorState } from "../lib/visitorState";

export const prerender = false;

const { latest, recent, version } = getVisitorState();
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Visitor API Dashboard</title>
		<style>
			:root {
				--bg-a: #eef5ff;
				--bg-b: #e9fff2;
				--card: rgba(255, 255, 255, 0.86);
				--line: rgba(15, 23, 42, 0.12);
				--main: #0f172a;
				--sub: #334155;
			}

			* { box-sizing: border-box; }

			body {
				margin: 0;
				min-height: 100vh;
				padding: 18px;
				font-family: "Avenir Next", "PingFang SC", "Microsoft YaHei", sans-serif;
				background:
					radial-gradient(circle at 10% 0%, #b8d7ff 0%, transparent 35%),
					radial-gradient(circle at 90% 100%, #a7f3d0 0%, transparent 35%),
					linear-gradient(135deg, var(--bg-a), var(--bg-b));
				color: var(--main);
				display: grid;
				grid-template-columns: minmax(240px, 320px) minmax(320px, 680px);
				gap: 14px;
				align-content: center;
				justify-content: center;
			}

			.card {
				background: var(--card);
				border: 1px solid var(--line);
				border-radius: 16px;
				box-shadow: 0 14px 30px rgba(15, 23, 42, 0.12);
				backdrop-filter: blur(6px);
			}

			.history { padding: 12px; }
			.history h2 { margin: 0 0 8px; font-size: 14px; color: var(--sub); }
			.history ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 6px; }
			.history li {
				display: flex;
				justify-content: space-between;
				align-items: center;
				gap: 8px;
				font-size: 12px;
				padding: 7px 8px;
				border-radius: 10px;
				border: 1px solid var(--line);
				background: rgba(255,255,255,0.8);
			}
			.row-left { display: inline-flex; align-items: center; gap: 6px; min-width: 0; }
			.row-left img { width: 18px; height: 13px; border-radius: 2px; border: 1px solid var(--line); object-fit: cover; }
			.row-left span { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 120px; }
			.row-time { color: var(--sub); white-space: nowrap; }

			.main { padding: 18px; }
			.badge {
				display: inline-flex;
				align-items: center;
				gap: 8px;
				padding: 8px 12px;
				border: 1px solid var(--line);
				border-radius: 999px;
				background: rgba(255,255,255,0.9);
				font-weight: 700;
			}
			.badge img { width: 26px; height: 18px; border-radius: 3px; border: 1px solid var(--line); object-fit: cover; }
			h1 { margin: 12px 0 6px; font-size: clamp(22px, 5vw, 32px); }
			.sub { margin: 0 0 14px; color: var(--sub); font-size: 14px; }
			.grid { display: grid; gap: 8px; }
			.item {
				display: flex; justify-content: space-between; gap: 12px;
				padding: 10px 12px; border-radius: 10px; border: 1px solid var(--line); background: rgba(255,255,255,0.76);
			}
			.key { color: var(--sub); font-weight: 600; }
			.value { font-weight: 700; text-align: right; word-break: break-all; }

			.api {
				margin-top: 14px;
				padding: 10px 12px;
				border-radius: 10px;
				border: 1px dashed var(--line);
				background: rgba(255,255,255,0.6);
				font-size: 12px;
				line-height: 1.5;
			}
			code { font-family: Consolas, "Courier New", monospace; }

			@media (max-width: 880px) {
				body { grid-template-columns: 1fr; align-content: start; }
			}
		</style>
	</head>
	<body data-version={String(version)}>
		<aside class="card history">
			<h2>最近 5 条来访更新</h2>
			<ul id="recent-list">
				{recent.map((item) => (
					<li>
						<span class="row-left">
							{item.flag.startsWith("http") ? <img src={item.flag} alt="flag" loading="eager" /> : <span>{item.flag}</span>}
							<span>{item.ip}</span>
						</span>
						<span class="row-time">{item.time}</span>
					</li>
				))}
			</ul>
		</aside>

		<main class="card main">
			<div class="badge" id="latest-flag-wrap">
				{latest?.flag?.startsWith("http") ? (
					<img id="latest-flag-img" src={latest.flag} alt="flag" loading="eager" />
				) : (
					<span id="latest-flag-text">{latest?.flag ?? "🏳️"}</span>
				)}
				<span>Latest</span>
			</div>
			<h1>实时来访者信息</h1>
			<p class="sub">数据来自外部网站调用 API 推送。</p>

			<section class="grid">
				<div class="item"><span class="key">IP</span><span class="value" id="latest-ip">{latest?.ip ?? "-"}</span></div>
				<div class="item"><span class="key">时间</span><span class="value" id="latest-time">{latest?.time ?? "-"}</span></div>
				<div class="item"><span class="key">版本</span><span class="value" id="latest-version">{String(version)}</span></div>
			</section>

			<div class="api">
				<div>写入接口（GET）：<code>/api/report-visitor.json?ip=1.2.3.4&flag=🇯🇵&time=2026-04-05%2013:20:00</code></div>
				<div>写入接口（POST JSON）：<code>&#123;"ip":"1.2.3.4","flag":"https://.../jp.png","time":"2026-04-05 13:20:00"&#125;</code></div>
				<div>读取接口：<code>/api/latest-visitor.json</code></div>
			</div>
		</main>

		<script>
			let knownVersion = Number(document.body.dataset.version || "0");

			const latestIpEl = document.getElementById("latest-ip");
			const latestTimeEl = document.getElementById("latest-time");
			const latestVersionEl = document.getElementById("latest-version");
			const latestFlagWrapEl = document.getElementById("latest-flag-wrap");
			const recentListEl = document.getElementById("recent-list");

			const renderLatestFlag = (flag) => {
				if (!latestFlagWrapEl) return;
				const oldImg = document.getElementById("latest-flag-img");
				const oldText = document.getElementById("latest-flag-text");
				if (oldImg) oldImg.remove();
				if (oldText) oldText.remove();

				if (typeof flag === "string" && flag.startsWith("http")) {
					const img = document.createElement("img");
					img.id = "latest-flag-img";
					img.src = flag;
					img.alt = "flag";
					img.loading = "eager";
					latestFlagWrapEl.insertBefore(img, latestFlagWrapEl.firstChild);
					return;
				}
				const span = document.createElement("span");
				span.id = "latest-flag-text";
				span.textContent = flag || "🏳️";
				latestFlagWrapEl.insertBefore(span, latestFlagWrapEl.firstChild);
			};

			const renderRecent = (recent) => {
				if (!recentListEl) return;
				recentListEl.innerHTML = "";
				for (const item of (recent || []).slice(0, 5)) {
					const li = document.createElement("li");
					const left = document.createElement("span");
					left.className = "row-left";

					if (typeof item.flag === "string" && item.flag.startsWith("http")) {
						const img = document.createElement("img");
						img.src = item.flag;
						img.alt = "flag";
						img.loading = "eager";
						left.appendChild(img);
					} else {
						const flagText = document.createElement("span");
						flagText.textContent = item.flag || "🏳️";
						left.appendChild(flagText);
					}

					const ip = document.createElement("span");
					ip.textContent = item.ip || "Unknown";
					left.appendChild(ip);

					const time = document.createElement("span");
					time.className = "row-time";
					time.textContent = item.time || "-";

					li.appendChild(left);
					li.appendChild(time);
					recentListEl.appendChild(li);
				}
			};

			const poll = async () => {
				try {
					const res = await fetch("/api/latest-visitor.json", { cache: "no-store" });
					if (!res.ok) return;
					const data = await res.json();
					const nextVersion = Number(data.version || 0);
					if (nextVersion <= knownVersion) return;

					const latest = data.latest || null;
					if (latest) {
						if (latestIpEl) latestIpEl.textContent = latest.ip || "-";
						if (latestTimeEl) latestTimeEl.textContent = latest.time || "-";
						renderLatestFlag(latest.flag || "🏳️");
					}

					renderRecent(Array.isArray(data.recent) ? data.recent : []);
					if (latestVersionEl) latestVersionEl.textContent = String(nextVersion);
					knownVersion = nextVersion;
				} catch {
					// ignore polling errors
				}
			};

			setInterval(poll, 2000);
		</script>
	</body>
</html>
