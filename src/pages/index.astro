---
export const prerender = false;
const cf = Astro.request.cf ?? {};

const ipHeader = Astro.request.headers.get("cf-connecting-ip")
	?? Astro.request.headers.get("x-forwarded-for")
	?? Astro.clientAddress
	?? "Unknown";

const countryCode = typeof cf.country === "string" && cf.country.length === 2
	? cf.country.toUpperCase()
	: "";

const toFlag = (code) => {
	if (!/^[A-Z]{2}$/.test(code)) return "🏳️";
	return String.fromCodePoint(...[...code].map((char) => 127397 + char.charCodeAt(0)));
};

const countryName = cf.countryName ?? countryCode ?? "Unknown";
const city = cf.city ?? "Unknown City";
const region = cf.region ?? "Unknown Region";
const locationText = `${city}, ${region}`;
const flag = toFlag(countryCode);
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Visitor Info</title>
		<style>
			:root {
				color-scheme: light;
			}
			* {
				box-sizing: border-box;
			}
			body {
				margin: 0;
				min-height: 100vh;
				display: grid;
				place-items: center;
				background: #ffffff;
				font-family: "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif;
			}
			#panel {
				display: grid;
				gap: 10px;
				padding: 20px 24px;
				border: 1px solid #d8d8d8;
				border-radius: 12px;
				min-width: min(90vw, 420px);
				background: #ffffff;
				color: #111111;
			}
			.title {
				font-size: 24px;
				font-weight: 600;
			}
			.line {
				font-size: 16px;
				line-height: 1.5;
			}
		</style>
	</head>
	<body>
		<div id="panel">
			<div class="title">{flag} {countryName}</div>
			<div class="line">IP: {ipHeader}</div>
			<div class="line">地址: {locationText}</div>
		</div>
		<script>
			setTimeout(() => {
				const panel = document.getElementById("panel");
				if (panel) panel.remove();
			}, 1000);
		</script>
	</body>
</html>

