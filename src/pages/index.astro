---
import { buildVisitorFromRequest, upsertLatestVisitor } from "../lib/visitorState";

export const prerender = false;

const currentVisitor = buildVisitorFromRequest(Astro.request, Astro.clientAddress);
const { visitor: shownVisitor, version } = upsertLatestVisitor(currentVisitor);

const locationText = `${shownVisitor.city}, ${shownVisitor.region}`;
const flagImageUrl = shownVisitor.countryCode
	? `https://flagcdn.com/w80/${shownVisitor.countryCode.toLowerCase()}.png`
	: "";
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Latest Visitor</title>
		<style>
			:root {
				--bg-1: #f6f9ff;
				--bg-2: #e8fff7;
				--card: rgba(255, 255, 255, 0.82);
				--text-main: #0f172a;
				--text-sub: #334155;
				--line: rgba(15, 23, 42, 0.12);
				--toast: rgba(15, 23, 42, 0.94);
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				min-height: 100vh;
				display: grid;
				place-items: center;
				padding: 24px;
				font-family: "Avenir Next", "PingFang SC", "Microsoft YaHei", sans-serif;
				background:
					radial-gradient(circle at 15% 10%, #b8d9ff 0%, transparent 40%),
					radial-gradient(circle at 85% 85%, #a7f3d0 0%, transparent 45%),
					linear-gradient(135deg, var(--bg-1), var(--bg-2));
				color: var(--text-main);
			}

			.panel {
				width: min(92vw, 540px);
				padding: 24px;
				border-radius: 22px;
				background: var(--card);
				backdrop-filter: blur(8px);
				border: 1px solid var(--line);
				box-shadow: 0 20px 50px rgba(15, 23, 42, 0.12);
			}

			.badge {
				display: inline-flex;
				align-items: center;
				gap: 10px;
				padding: 8px 14px;
				border-radius: 999px;
				background: rgba(255, 255, 255, 0.92);
				border: 1px solid var(--line);
				font-size: 18px;
				font-weight: 700;
			}

			.flag-icon {
				width: 28px;
				height: 20px;
				border-radius: 4px;
				border: 1px solid var(--line);
				object-fit: cover;
				background: #fff;
			}

			h1 {
				margin: 16px 0 8px;
				font-size: clamp(24px, 5vw, 34px);
				line-height: 1.15;
			}

			.meta {
				margin: 0 0 18px;
				font-size: 14px;
				color: var(--text-sub);
			}

			.list {
				display: grid;
				gap: 10px;
			}

			.item {
				display: flex;
				justify-content: space-between;
				gap: 14px;
				padding: 12px 14px;
				border-radius: 12px;
				background: rgba(255, 255, 255, 0.72);
				border: 1px solid var(--line);
			}

			.key {
				font-weight: 600;
				color: var(--text-sub);
			}

			.value {
				font-weight: 700;
				word-break: break-all;
				text-align: right;
			}

			#update-toast {
				position: fixed;
				top: 12px;
				left: 12px;
				max-width: min(80vw, 320px);
				padding: 10px 12px;
				border-radius: 10px;
				background: var(--toast);
				color: #ffffff;
				font-size: 13px;
				line-height: 1.4;
				box-shadow: 0 12px 24px rgba(15, 23, 42, 0.28);
				opacity: 0;
				transform: translateY(-8px);
				pointer-events: none;
				transition: opacity 0.25s ease, transform 0.25s ease;
			}

			#update-toast.show {
				opacity: 1;
				transform: translateY(0);
			}
		</style>
	</head>
	<body data-version={String(version)} data-country={shownVisitor.countryCode}>
		<div id="update-toast" role="status" aria-live="polite"></div>

		<main class="panel">
			<div class="badge" id="country-badge">
				{flagImageUrl ? (
					<img
						class="flag-icon"
						id="flag-image"
						src={flagImageUrl}
						alt={`${shownVisitor.countryName} flag`}
						loading="eager"
					/>
				) : (
					<span id="flag-emoji">{shownVisitor.flag}</span>
				)}
				<span id="country-name">{shownVisitor.countryName}</span>
			</div>
			<h1>最近访问者</h1>
			<p class="meta">仅在检测到新 IP 时切换显示</p>

			<section class="list" aria-label="visitor info">
				<div class="item">
					<span class="key">IP</span>
					<span class="value" id="visitor-ip">{shownVisitor.ip}</span>
				</div>
				<div class="item">
					<span class="key">地址</span>
					<span class="value" id="visitor-location">{locationText}</span>
				</div>
				<div class="item">
					<span class="key">国家代码</span>
					<span class="value" id="visitor-country-code">{shownVisitor.countryCode || "Unknown"}</span>
				</div>
				<div class="item">
					<span class="key">最近更新时间</span>
					<span class="value" id="visitor-updated-at">{shownVisitor.updatedAt}</span>
				</div>
			</section>
		</main>

		<script>
			const toFlag = (code) => {
				if (!/^[A-Z]{2}$/.test(code)) return "🏳️";
				return String.fromCodePoint(...[...code].map((char) => 127397 + char.charCodeAt(0)));
			};

			const body = document.body;
			let knownVersion = Number(body.dataset.version || "0");
			let knownCountry = body.dataset.country || "";
			let toastTimer = null;

			const toastEl = document.getElementById("update-toast");
			const countryNameEl = document.getElementById("country-name");
			const ipEl = document.getElementById("visitor-ip");
			const locationEl = document.getElementById("visitor-location");
			const countryCodeEl = document.getElementById("visitor-country-code");
			const updatedAtEl = document.getElementById("visitor-updated-at");
			const badgeEl = document.getElementById("country-badge");

			const showToast = (message) => {
				if (!toastEl) return;
				toastEl.textContent = message;
				toastEl.classList.add("show");
				clearTimeout(toastTimer);
				toastTimer = setTimeout(() => {
					toastEl.classList.remove("show");
				}, 3200);
			};

			const renderFlag = (countryCode, countryName) => {
				if (!badgeEl) return;
				const oldImg = document.getElementById("flag-image");
				const oldEmoji = document.getElementById("flag-emoji");

				if (oldImg) oldImg.remove();
				if (oldEmoji) oldEmoji.remove();

				if (/^[A-Z]{2}$/.test(countryCode)) {
					const img = document.createElement("img");
					img.id = "flag-image";
					img.className = "flag-icon";
					img.alt = `${countryName} flag`;
					img.loading = "eager";
					img.src = `https://flagcdn.com/w80/${countryCode.toLowerCase()}.png`;
					badgeEl.insertBefore(img, countryNameEl);
					return;
				}

				const span = document.createElement("span");
				span.id = "flag-emoji";
				span.textContent = toFlag(countryCode || "");
				badgeEl.insertBefore(span, countryNameEl);
			};

			const applyVisitor = (visitor) => {
				if (!visitor) return;
				if (countryNameEl) countryNameEl.textContent = visitor.countryName || "Unknown Country";
				if (ipEl) ipEl.textContent = visitor.ip || "Unknown";
				if (locationEl) locationEl.textContent = `${visitor.city || "Unknown City"}, ${visitor.region || "Unknown Region"}`;
				if (countryCodeEl) countryCodeEl.textContent = visitor.countryCode || "Unknown";
				if (updatedAtEl) updatedAtEl.textContent = visitor.updatedAt || "-";
				renderFlag(visitor.countryCode || "", visitor.countryName || "Unknown Country");
			};

			const pollLatest = async () => {
				try {
					const res = await fetch("/api/latest-visitor.json", { cache: "no-store" });
					if (!res.ok) return;
					const data = await res.json();
					const nextVersion = Number(data.version || 0);
					const visitor = data.visitor;
					if (!visitor || nextVersion <= knownVersion) return;

					const nextCountry = visitor.countryCode || "";
					if (nextCountry && knownCountry && nextCountry !== knownCountry) {
						showToast(`${visitor.countryName || "未知国家"} 的用户访问了`);
					}

					applyVisitor(visitor);
					knownVersion = nextVersion;
					knownCountry = nextCountry;
				} catch {
					// Keep silent while polling.
				}
			};

			setInterval(pollLatest, 2500);
		</script>
	</body>
</html>
