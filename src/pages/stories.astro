---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionPostList from '../components/SectionPostList.astro';
import { SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
	.filter((post) => post.data.section === 'stories')
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`小故事 | ${SITE_TITLE}`} description="小故事栏目文章列表" />
	</head>
	<body>
		<Header />
		<main>
			<SectionPostList title="小故事" description="记录真实交流与关系中的细节。" posts={posts} />
		</main>
		<Footer />
	</body>
</html>
