---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SectionPostList from '../components/SectionPostList.astro';
import { SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
	.filter((post) => post.data.section === 'beginner')
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={`拳交入门 | ${SITE_TITLE}`} description="拳交入门栏目文章列表" />
	</head>
	<body>
		<Header />
		<main>
			<SectionPostList title="拳交入门" description="从基础沟通、安全与准备开始。" posts={posts} />
		</main>
		<Footer />
	</body>
</html>
